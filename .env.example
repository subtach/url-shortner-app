# Turso (cloud SQLite) — required for ALL features to work
# Get these from: https://turso.tech → your database → Generate Token
#
# IMPORTANT for Netlify deployment:
#   .env.local is gitignored and never uploaded to Netlify.
#   You MUST add these two variables in:
#   Netlify Dashboard → Site Settings → Environment Variables
#
TURSO_DATABASE_URL=libsql://your-db-name-username.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
